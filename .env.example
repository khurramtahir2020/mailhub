# Database (Coolify PostgreSQL)
DATABASE_URL=postgres://user:password@your-coolify-host:5432/mailhub?sslmode=require

# Auth0
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_AUDIENCE=https://api.mailhub.com
AUTH0_CLIENT_ID=your-spa-client-id

# Server
PORT=3000
NODE_ENV=development
LOG_LEVEL=debug

# Frontend (build-time)
VITE_AUTH0_DOMAIN=your-tenant.auth0.com
VITE_AUTH0_CLIENT_ID=your-spa-client-id
VITE_AUTH0_AUDIENCE=https://api.mailhub.com
VITE_API_URL=http://localhost:3000/api/v1

# AWS SES
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=eu-central-1
SES_CONFIGURATION_SET=mailhub-production
